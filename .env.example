# Copy this file to `.env` and fill in real values. Never commit your real `.env` to git.
# Vite requires env vars to be prefixed with VITE_

# Supabase (client anon key). For server-side inserts use service_role key on a secure server only.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=REPLACE_WITH_YOUR_ANON_KEY

# OpenWeatherMap
VITE_WEATHER_API_KEY=REPLACE_WITH_YOUR_OPENWEATHERMAP_KEY
VITE_WEATHER_CITY=Chennai

# Optional: webhook for alerts (example)
EMAIL_WEBHOOK_URL="https://hooks.slack.com/services/YOUR_WORKSPACE_ID/YOUR_CHANNEL_ID/YOUR_SECRET_TOKEN"

# Notes:
# - The Supabase anon key is OK for client-side reads. Do NOT use the service_role key in front-end code.
# - If you need to persist alerts from untrusted clients, consider inserting via a server/edge function using the service_role key.
# - After creating `.env`, restart the dev server so Vite picks up the values.